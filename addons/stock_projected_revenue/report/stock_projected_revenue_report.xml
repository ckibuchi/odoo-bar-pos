<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PDF Report Action -->
    <record id="action_report_stock_projected_revenue" model="ir.actions.report">
        <field name="name">Stock Projected Revenue</field>
        <field name="model">stock.projected.revenue</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_projected_revenue.report_stock_projected_revenue_template</field>
        <field name="report_file">stock_projected_revenue.report_stock_projected_revenue_template</field>
        <field name="print_report_name">'Stock Projected Revenue - %s' % (object.env['res.company'].search([], limit=1).name)</field>
        <field name="binding_model_id" ref="model_stock_projected_revenue"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_a4"/>
    </record>

    <!-- XLSX Report Action -->
    <record id="action_report_stock_projected_revenue_xlsx" model="ir.actions.report">
        <field name="name">Stock Projected Revenue (Excel)</field>
        <field name="model">stock.projected.revenue</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">stock.projected.revenue.xlsx</field>
        <field name="report_file">stock_projected_revenue.report_stock_projected_revenue_xlsx</field>
        <field name="print_report_name">'Stock_Projected_Revenue'</field>
        <field name="binding_model_id" ref="model_stock_projected_revenue"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
