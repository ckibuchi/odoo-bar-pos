<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_stock_projected_revenue_template">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <div class="page">

                <!-- Header -->
                <div class="row mb-4">
                    <div class="col-12 text-center">
                        <h2>Stock Projected Revenue Report</h2>
                        <p class="text-muted">
                            Generated on:
                            <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M:%S')"/>
                        </p>
                    </div>
                </div>

                <!-- Summary Totals -->
                <t t-set="all_records" t-value="docs"/>
                <t t-set="total_cost" t-value="sum(docs.mapped('total_cost_value'))"/>
                <t t-set="total_revenue" t-value="sum(docs.mapped('projected_revenue'))"/>
                <t t-set="total_profit" t-value="sum(docs.mapped('potential_profit'))"/>

                <div class="row mb-4">
                    <div class="col-4 text-center border rounded p-3">
                        <h5>Total Stock Cost</h5>
                        <h4 t-esc="'{:,.2f}'.format(total_cost)"/>
                    </div>
                    <div class="col-4 text-center border rounded p-3">
                        <h5>Total Projected Revenue</h5>
                        <h4 t-esc="'{:,.2f}'.format(total_revenue)"/>
                    </div>
                    <div class="col-4 text-center border rounded p-3">
                        <h5>Potential Profit</h5>
                        <h4 t-esc="'{:,.2f}'.format(total_profit)"/>
                    </div>
                </div>

                <!-- Product Table -->
                <table class="table table-sm table-bordered table-striped">
                    <thead style="background-color:#875A7B; color:white;">
                        <tr>
                            <th>#</th>
                            <th>Product</th>
                            <th>Category</th>
                            <th class="text-right">Qty on Hand</th>
                            <th class="text-right">Cost Price</th>
                            <th class="text-right">Sale Price</th>
                            <th class="text-right">Total Cost Value</th>
                            <th class="text-right">Projected Revenue</th>
                            <th class="text-right">Potential Profit</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="counter" t-value="1"/>
                        <t t-foreach="docs" t-as="line">
                            <tr>
                                <td><t t-esc="counter"/></td>
                                <td><t t-esc="line.product_name"/></td>
                                <td><t t-esc="line.category_id.name"/></td>
                                <td class="text-right"><t t-esc="'{:,.2f}'.format(line.qty_on_hand)"/></td>
                                <td class="text-right"><t t-esc="'{:,.2f}'.format(line.cost_price)"/></td>
                                <td class="text-right"><t t-esc="'{:,.2f}'.format(line.sale_price)"/></td>
                                <td class="text-right"><t t-esc="'{:,.2f}'.format(line.total_cost_value)"/></td>
                                <td class="text-right"><t t-esc="'{:,.2f}'.format(line.projected_revenue)"/></td>
                                <td class="text-right"><t t-esc="'{:,.2f}'.format(line.potential_profit)"/></td>
                            </tr>
                            <t t-set="counter" t-value="counter + 1"/>
                        </t>
                    </tbody>
                    <tfoot style="font-weight:bold; background-color:#f5f5f5;">
                        <tr>
                            <td colspan="6" class="text-right">TOTALS</td>
                            <td class="text-right"><t t-esc="'{:,.2f}'.format(total_cost)"/></td>
                            <td class="text-right"><t t-esc="'{:,.2f}'.format(total_revenue)"/></td>
                            <td class="text-right"><t t-esc="'{:,.2f}'.format(total_profit)"/></td>
                        </tr>
                    </tfoot>
                </table>

            </div>
        </t>
    </t>
</template>
</odoo>
